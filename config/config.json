{
  "email": {
    "smtp": {
      "host": "${SMTP_HOST}",
      "port": "${SMTP_PORT}",
      "secure": true,
      "user": "${SMTP_USER}",
      "pass": "${SMTP_PASS}"
    },
    "from": "${SMTP_USER}"
  },
  "llm": {
    "enabled": true,
    "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
    "apiKey": "${LLM_API_KEY}",
    "model": "glm-4-plus"
  },
  "modules": [
    {
      "name": "示例模块 A",
      "keywords": [
        "your pubmed search string here"
      ],
      "recipients": ["example1@example.com"],
      "maxResults": 15,
      "daysBack": 7,
      "fallbackFromYear": 2020,
      "fallbackMaxResults": 10
    },
    {
      "name": "示例模块 B",
      "keywords": [
        "another pubmed search string"
      ],
      "recipients": ["example1@example.com", "example2@example.com"],
      "maxResults": 15,
      "daysBack": 7,
      "enabled": false
    },
    {
      "name": "示例模块 C",
      "keywords": [
        "example[Title/Abstract]"
      ],
      "recipients": ["example1@example.com"],
      "maxResults": 15,
      "daysBack": 7,
      "fallbackFromYear": 2020,
      "fallbackMaxResults": 10
    },
    {
      "name": "示例预印本模块",
      "keywords": ["example keyword 1", "example keyword 2"],
      "recipients": ["example1@example.com"],
      "maxResults": 10,
      "daysBack": 7,
      "sources": [],
      "preprint": {
        "enabled": true,
        "server": "biorxiv",
        "category": "immunology",
        "daysBack": 7,
        "maxResults": 10
      },
      "enabled": true
    }
  ]
}
